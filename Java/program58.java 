import java.util.Scanner;

public class program58 {
    public static void main(String[] args) {
        Scanner sobj = new Scanner(System.in);

        System.out.println("Enter a positive integer:");
        if (sobj.hasNextInt()) {
            int iValue = sobj.nextInt();
            boolean bRet = isPrime(iValue); 

            if (bRet) {
                System.out.println(iValue + " is a prime number.");
            } else {
                System.out.println(iValue + " is not a prime number.");
            }
        }
        
        sobj.close();
    }

    public static boolean isPrime(int iNo) {
        if (iNo < 2) return false;
        if (iNo == 2) return true;
        if (iNo % 2 == 0) return false; // Optimization: exclude even numbers

        // Optimization: Only check up to the square root of iNo
        for (int i = 3; i <= Math.sqrt(iNo); i += 2) {
            if (iNo % i == 0) {
                return false;
            }
        }

        return true;
    }
}